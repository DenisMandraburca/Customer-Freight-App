# Shared
APP_URL=http://localhost:5174
API_URL=http://localhost:8787
JWT_SECRET=change-me
COOKIE_DOMAIN=localhost
COMPANY_DOMAINS=afctransport.com,afclogistics.com

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8787/api/auth/google/callback

# DB (Supabase preferred mode)
# SUPABASE_URL example: https://your-project-ref.supabase.co
SUPABASE_URL=
SUPABASE_DB_PASSWORD=
# Optional overrides (defaults shown):
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_NAME=postgres

# Alternative direct URI mode
DATABASE_URL=
SUPABASE_DB_URL=
# SSL mode: require | disable (blank = auto; Supabase auto-enables SSL)
PGSSL=

# Optional for frontend direct Supabase calls (not used by backend DB connection)
PUBLISHABLE_API_KEY=

# Web
VITE_API_BASE=http://localhost:8787
