# Shared
APP_URL=http://localhost:5174
API_URL=http://localhost:8787
API_BASE_PATH=/api/customer-freight
LOG_LEVEL=debug
COMPANY_DOMAINS=afctransport.com,afclogistics.com

# Local standalone defaults (SQLite + dev session shim)
DB_PROVIDER=sqlite
SQLITE_URL=file:./data/dev.db
DEV_AUTH_ENABLED=true
DEV_SESSION_ID=dev-local-user
DEV_SESSION_EMAIL=local.admin@afctransport.com
DEV_SESSION_NAME=Local Dev Admin
DEV_SESSION_PERMISSIONS=customer-freight:access,customer-freight:admin
DEV_SESSION_SUPER_ADMIN=false

# DB (PostgreSQL / Supabase remote profile)
# Set DB_PROVIDER=postgres for remote DB usage.
# SUPABASE_URL example: https://your-project-ref.supabase.co
SUPABASE_URL=
SUPABASE_DB_PASSWORD=
# Optional overrides (defaults shown):
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_NAME=postgres

# Alternative direct URI mode
DATABASE_URL=
SUPABASE_DB_URL=
# SSL mode: require | disable (blank = auto; Supabase auto-enables SSL)
PGSSL=

# Web
VITE_API_BASE=http://localhost:8787
# Optional override: default is /login in dev and /apps/hub/login in production.
VITE_PORTAL_LOGIN_URL=
