generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNT_MANAGER
  DISPATCHER
  VIEWER
  BANNED

  @@map("user_role")
}

enum LoadStatus {
  AVAILABLE
  PENDING_APPROVAL
  QUOTE_SUBMITTED
  COVERED
  LOADED
  DELAYED
  DELIVERED
  BROKERAGE
  CANCELED
  TONU

  @@map("load_status")
}

model User {
  id             String   @id
  email          String   @unique
  name           String
  role           UserRole @default(DISPATCHER)
  fullLoadAccess Boolean  @default(false) @map("full_load_access")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  managedLoads   Load[]   @relation("LoadAccountManager")
  dispatchLoads  Load[]   @relation("LoadDispatcher")
  sentChatMessages    LoadChatMessage[] @relation("LoadChatSender")
  targetedChatMessages LoadChatMessage[] @relation("LoadChatTargetUser")
  chatReadStates       LoadChatRead[]

  @@map("users")
}

model Customer {
  id          String    @id
  name        String    @unique
  type        String
  quoteAccept Boolean   @default(false) @map("quote_accept")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  loads       Load[]

  @@map("customers")
}

model GreenbushBank {
  id             String    @id
  legacyId       String?   @unique(map: "idx_greenbush_legacy_id_unique") @map("legacy_id")
  pickupLocation String    @map("pickup_location")
  destination    String
  receivingHours String?   @map("receiving_hours")
  price          Decimal
  tarp           String?
  remainingCount Int       @default(0) @map("remaining_count")
  reservedCount  Int       @default(0) @map("reserved_count")
  specialNotes   String?   @map("special_notes")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @map("updated_at")

  loads          Load[]

  @@map("greenbush_bank")
}

model Load {
  id                   String      @id
  legacyId             String?     @unique(map: "idx_loads_legacy_id_unique") @map("legacy_id")
  createdAt            DateTime    @default(now()) @map("created_at")
  status               LoadStatus  @default(AVAILABLE)
  accountManagerId     String?     @map("account_manager_id")
  customerId           String?     @map("customer_id")
  loadRefNumber        String      @map("load_ref_number")
  mcleodOrderId        String?     @map("mcleod_order_id")
  requestedPickupDate  DateTime?   @map("requested_pickup_date")
  puCity               String      @map("pu_city")
  puState              String      @map("pu_state")
  puZip                String?     @map("pu_zip")
  puDate               DateTime?   @map("pu_date")
  puApptTime           String?     @map("pu_appt_time")
  puAppt               Boolean     @default(false) @map("pu_appt")
  delCity              String      @map("del_city")
  delState             String      @map("del_state")
  delZip               String?     @map("del_zip")
  delDate              DateTime?   @map("del_date")
  delApptTime          String?     @map("del_appt_time")
  delAppt              Boolean     @default(false) @map("del_appt")
  rate                 Decimal
  miles                Decimal
  rpm                  Decimal
  notes                String?
  equipment            String?
  assignedDispatcherId String?     @map("assigned_dispatcher_id")
  driverName           String?     @map("driver_name")
  truckNumber          String?     @map("truck_number")
  reasonLog            String?     @map("reason_log")
  delayReason          String?     @map("delay_reason")
  cancelReason         String?     @map("cancel_reason")
  denyQuoteReason      String?     @map("deny_quote_reason")
  otherNotes           String?     @map("other_notes")
  greenbushBankId      String?     @map("greenbush_bank_id")

  accountManager       User?        @relation("LoadAccountManager", fields: [accountManagerId], references: [id])
  customer             Customer?    @relation(fields: [customerId], references: [id])
  dispatcher           User?        @relation("LoadDispatcher", fields: [assignedDispatcherId], references: [id])
  greenbushBank        GreenbushBank? @relation(fields: [greenbushBankId], references: [id])
  chatMessages         LoadChatMessage[]
  chatSettings         LoadChatSetting?
  chatRetention        LoadChatRetention?
  chatReadStates       LoadChatRead[]

  @@index([status], map: "idx_loads_status")
  @@index([assignedDispatcherId], map: "idx_loads_dispatcher")
  @@index([customerId], map: "idx_loads_customer")
  @@index([puDate], map: "idx_loads_pu_date")
  @@map("loads")
}

model LoadChatMessage {
  id           String   @id
  loadId       String   @map("load_id")
  senderUserId String?  @map("sender_user_id")
  senderName   String   @map("sender_name")
  messageText  String   @map("message_text")
  messageType  String   @map("message_type")
  targetScope  String   @map("target_scope")
  targetUserId String?  @map("target_user_id")
  systemEvent  String?  @map("system_event")
  createdAt    DateTime @default(now()) @map("created_at")

  load         Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  senderUser   User?    @relation("LoadChatSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("LoadChatTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([loadId, createdAt], map: "idx_load_chat_messages_load_created_at")
  @@index([targetUserId], map: "idx_load_chat_messages_target_user")
  @@map("load_chat_messages")
}

model LoadChatSetting {
  loadId            String  @id @map("load_id")
  protectFromPurge  Boolean @default(false) @map("protect_from_purge")

  load              Load    @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@map("load_chat_settings")
}

model LoadChatRetention {
  loadId     String   @id @map("load_id")
  purgeAfter DateTime @map("purge_after")

  load       Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@index([purgeAfter], map: "idx_load_chat_retention_purge_after")
  @@map("load_chat_retention")
}

model LoadChatRead {
  userId     String   @map("user_id")
  loadId     String   @map("load_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  load       Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@id([userId, loadId])
  @@index([loadId, userId], map: "idx_load_chat_reads_load_user")
  @@map("load_chat_reads")
}
