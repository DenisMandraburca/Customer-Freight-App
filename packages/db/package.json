{
  "name": "@antigravity/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:migrate:dev": "prisma migrate dev --config prisma.config.ts",
    "migrate": "tsx src/migrate.ts",
    "import-legacy": "tsx src/importLegacyCsv.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "test": "echo \"No standalone tests in @antigravity/db\"",
    "lint": "echo \"No lint configured for @antigravity/db\"",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@antigravity/shared": "0.1.0",
    "@prisma/adapter-pg": "7.3.0",
    "@prisma/client": "7.3.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.5",
    "prisma": "7.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
